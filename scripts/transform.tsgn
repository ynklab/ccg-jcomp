% insert nofa(noun form of adjective) pos tag
/^NP`case~nc,mod~nm,fin~f'.*$/=x <: 身長

relabel x /NP`case~nc,mod~nm,fin~f,nofa~true';名詞;一般;*/

/^NP`case~nc,mod~nm,fin~f'.*$/=x <: 体重

relabel x /NP`case~nc,mod~nm,fin~f,nofa~true';名詞;一般;*/

/^<S`.*'\/S`.*'>\\NP`(?!.*nofa~true).*'.*$/=x <: は $-- (/^NP`.*'$/ <- /^NP`.*nofa~true.*'.*$/)

relabel x /<S`mod~X1,form~X2,fin~f'\/S`mod~X1,form~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f,nofa~true';助詞;係助詞;*/

% modify PC-6082
/^NP`.*'$/=x <, (/^NP`.*'.*$/ <: PC) <- (/^NP`.*'$/ <, (/^NP`.*'.*/ <: /-/) <- (/^NP`.*'.*/ <: /6082/))

relabel x /NP`case~nc,mod~nm,fin~f';名詞;固有名詞;*;*/
replace x (NP`case~nc,mod~nm,fin~f';名詞;固有名詞;*;* PC-6082)

% modify ITEL-XZ
/^NP`.*'$/=x <, (/^NP`.*'.*$/ <: ITEL) <- (/^NP`.*'$/ <, (/^NP`.*'.*/ <: /-/) <- (/^NP`.*'.*/ <: XZ))

relabel x /NP`case~nc,mod~nm,fin~f';名詞;固有名詞;*;*/
