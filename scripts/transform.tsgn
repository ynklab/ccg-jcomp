delete z
excise y y

% に + 比べる + と -> に比べると
/^S`.*'$/=x $++ (/^<S`.*'\/S`.*'>\\S`.*'.*$/=y <: と) <- (/^S`.*'\\NP`.*'.*$/=z <: 比べる) <, (/^NP`.*'$/=w <- (/^NP`.*'\\NP`.*'.*$/=u <: に))

delete u
excise w w
delete z
excise x x
replace y (<S`mod~X1,form~X2,fin~f'/S`mod~X1,form~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f' に比べると)

% で + は + ない -> ではない
/^S`.*'$/ <- (/^S`.*'\\S`.*'.*$/=y <: ない) <, (/^S`.*'$/=z <- (/^S`.*'\\S`.*'.*$/=w <: は) <, (/^S`.*'$/=u <- (/^S`.*'\\NP`.*'.*$/=v <: で)))

delete v
excise u u
delete w
excise z z
