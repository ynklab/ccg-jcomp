% modify ITEL-ZY
/^NP`.*'$/=x <, (/^NP`.*'.*$/ <: ITEL) <- (/^NP`.*'$/ <, (/^NP`.*'.*/ <: /-/) <- (/^NP`.*'.*/ <: ZY))

replace x (NP`case~nc,mod~nm,fin~f';名詞;固有名詞;*;* ITEL-ZY)

% add adj pos tag (ex. 太郎は次郎より3冊多くの本を買った。)
/^S`.*'\\NP`.*'$/=a <, (/^NP`case~o(?!.*adj~true).*'$/=x <- /^NP`.*'\\NP`.*'.*$/=y <, (/^NP`.*'$/=z <, (/^NP`.*'\/NP`.*'$/=w <, (/^NP`.*'$/ <- (/^NP`.*'.*$/ <: 多く)) <- (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=t <: の)))) <- /^<S`.*'\\NP`.*'>\\NP`.*'.*$/=u $-- (/^S`.*'\/S`.*'$/=b <- /^<S`.*'\/S`.*'>\\NP`.*'.*$/=c)

relabel a /S`mod~nm,form~base,fin~f,adj~true'\\NP`case~ga,mod~nm,fin~f'/
relabel b /S`mod~X1,form~X2,fin~f'\/S`mod~X1,form~X2,fin~f,adj~true'/
relabel c /<S`mod~X1,form~X2,fin~f'\/S`mod~X1,form~X2,fin~f,adj~true'>\\NP`case~nc,mod~nm,fin~f';助詞;格助詞;一般;*/
relabel x /NP`case~o,mod~nm,fin~f,adj~true'/
relabel y /NP`case~o,mod~nm,fin~f,adj~true'\\NP`case~nc,mod~nm,fin~f,adj~true'/
relabel z /NP`case~nc,mod~nm,fin~f,adj~true'/
relabel w /NP`case~X1,mod~X2,fin~f,adj~true'\/NP`case~X1,mod~X2,fin~f'/
relabel u /<S`mod~nm,form~base,fin~f,adj~true'\\NP`case~ga,mod~nm,fin~f'>\\NP`case~o,mod~nm,fin~f,adj~true'/
relabel t /<NP`case~X1,mod~X2,fin~f,adj~true'\/NP`case~X1,mod~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f'/

/^<S`.*'\\NP`.*'>\\NP`.*adj~true'.*$/ <, /^<S`.*form~cont.*'\\NP`.*'>\\NP`(?!.*adj~true).*'.*$/=x

relabel x /<S`mod~nm,form~cont,fin~f,adj~true'\\NP`case~ga,mod~nm,fin~f'>\\NP`case~o,mod~nm,fin~f,adj~true'/

/^<S`.*'\\NP`.*'>\\NP`.*adj~true'.*$/ <, /^<S`.*form~stem.*'\\NP`.*'>\\NP`(?!.*adj~true).*'.*$/=x

relabel x /<S`mod~nm,form~stem,fin~f,adj~true'\\NP`case~ga,mod~nm,fin~f'>\\NP`case~o,mod~nm,fin~f,adj~true'/

/^S`(?!.*adj~true).*'\\S`.*'.*$/=x $-- /^<S`.*'\\NP`.*'>\\NP`.*adj~true.*'$/

relabel x /S`mod~nm,form~base,fin~f,adj~true'\\S`mod~nm,form~cont,fin~f,adj~true'/

% add mul pos tag (ex. 太郎は次郎の2倍の本を買った。)
/^NP`(?!.*mul~true).*'$/=x <, (/^NP`.*'\/NP`.*'$/=y <- (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=z <: の)) <- (/^NP`.*'$/ <, /^NP`.*';名詞;数.*$/ <- (/.*/ <: 倍))

relabel x /NP`case~nc,mod~nm,fin~f,mul~true'/
relabel y /NP`case~X1,mod~X2,fin~f,mul~true'\/NP`case~X1,mod~X2,fin~f'/
relabel z /<NP`case~X1,mod~X2,fin~f,mul~true'\/NP`case~X1,mod~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f'/

/^NP`(?!.*mul~true).*'\/NP`.*'$/=x <, /^NP`.*mul~true.*'$/ <- /^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=y

relabel x /NP`case~X1,mod~X2,fin~f,mul~true'\/NP`case~X1,mod~X2,fin~f'/
relabel y /<NP`case~X1,mod~X2,fin~f,mul~true'\/NP`case~X1,mod~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f,mul~true'/

/^NP`(?!.*mul~true).*'$/=x <, /^NP`.*mul~true'\/NP`.*'$/

relabel x /NP`case~nc,mod~nm,fin~f,mul~true'/

/^NP`(?!.*mul~true).*'$/=x <, /^NP`.*mul~true'$/ <- (/^NP`.*'\\NP`.*'.*$/=y <: を)

relabel x /NP`case~o,mod~nm,fin~f,mul~true'/
relabel y /NP`case~o,mod~nm,fin~f,mul~true'\\NP`case~nc,mod~nm,fin~f,mul~true'/

/^<S`.*'\\NP`.*'>\\NP`(?!.*mul~true).*'.*$/=x $-- /^NP`.*mul~true.*'$/

relabel x /<S`mod~nm,form~base,fin~f'\\NP`case~ga,mod~nm,fin~f'>\\NP`case~o,mod~nm,fin~f,mul~true'/

/^<S`.*'\\NP`.*'>\\NP`.*mul~true'.*$/ <, /^<S`.*form~cont.*'\\NP`.*'>\\NP`(?!.*mul~true).*'.*$/=x

relabel x /<S`mod~nm,form~cont,fin~f'\\NP`case~ga,mod~nm,fin~f'>\\NP`case~o,mod~nm,fin~f,mul~true'/

/^<S`.*'\\NP`.*'>\\NP`.*mul~true'.*$/ <, /^<S`.*form~stem.*'\\NP`.*'>\\NP`(?!.*mul~true).*'.*$/=x

relabel x /<S`mod~nm,form~stem,fin~f'\\NP`case~ga,mod~nm,fin~f'>\\NP`case~o,mod~nm,fin~f,mul~true'/

% より + も -> よりも (S/S)\NP
/^NP`.*'$/=x <- (/^NP`.*'\\NP`.*'.*$/=y <: より) $++ (/^<S`.*'\/S`.*'>\\NP`.*'.*$/=z <: /も/=w)

delete y
excise x x
relabel z /<S`mod~X1,form~X2,fin~f'\/S`mod~X1,form~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f';助詞;格助詞;一般;*/
relabel w /よりも/

% より + も -> よりも (NP/NP)\S
/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=x <: も=w $-- (/^NP`.*'$/=y <- (/^NP`.*'\\S`.*'.*$/=z <: より))

delete z
excise y y
relabel x /<NP`case~X1,mod~X2,fin~f'\/NP`case~X1,mod~X2,fin~f'>\\S`mod~nm,form~base,fin~f';*;*;*;*/
relabel w よりも

% より + も -> よりも (NP/NP)\NP
/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=x <: も=w $-- (/^NP`.*'$/=y <- (/^NP`.*'\\NP`.*'.*$/=z <: より))

delete z
excise y y
relabel x /<NP`case~X1,mod~X2,fin~f'\/NP`case~X1,mod~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f';*;*;*;*/
relabel w よりも

% 以上 + に -> 以上に
/^NP`.*'$/=x <, /^NP`.*'\/NP`.*'.*$/=u <- (/^NP`.*'.*$/=y <: 以上) $++ (/^<S`.*'\/S`.*'>\\NP`.*'.*$/=z <: /に/=w)

delete y
excise u u
relabel z /<S`mod~X1,form~X2,fin~f'\/S`mod~X1,form~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f';助詞;格助詞;一般;*/
relabel w /以上に/

% と + 同じ + くらい + の -> と同じくらいの
/^NP`.*'\/NP`.*'$/=x <, (/^NP`.*'.*$/ <: くらい) <- (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/ <: の) $-- (/^NP`.*'\/NP`.*'$/=y <- (/^NP`.*'\/NP`.*'.*$/=z <: 同じ) <, (/^NP`.*'\/NP`.*'$/=u <- (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=w <: と)))

delete w
excise u u
replace x (<NP`case~X1,mod~X2,fin~f'/NP`case~X1,mod~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f';*;*;*;* と同じくらいの)
delete z
excise y y

% と + 同じ + くらい -> と同じくらい
/^S`.*'\/S`.*'$/ <- (/^<S`.*'\/S`.*'>\\S`.*'.*$/=y <: くらい) <, (/^S`.*'$/=z <- (/^S`.*'.*$/=w <: 同じ) <, (/^S`.*'\/S`.*'$/=u <- (/^<S`.*'\/S`.*'>\\NP`.*'.*$/=v <: と)))

delete v
excise u u
delete w
excise z z
replace y (<S`mod~X1,form~X2,fin~f'/S`mod~X1,form~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f' と同じくらい)

% と + 同じ -> と同じ
/^NP`.*'\/NP`.*'$/=x $++ (/^NP`.*'\/NP`.*'.*$/=y <: 同じ) <- (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=z <: と)

delete z
excise x x
replace y (<NP`case~X1,mod~X2,fin~f'/NP`case~X1,mod~X2,fin~f'>\\NP`case~nc,mod~nm,fin~f';*;*;*;* と同じ)


% と + 少なくとも + 同じ + くらい + の -> と同じくらいの
/^NP`.*'\/NP`.*'$/=x <, (/^NP`.*'.*$/ <: くらい) <- (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/ <: の) $-- (/^NP`.*'\/NP`.*'$/=y <- (/^NP`.*'\/NP`.*'$/=z <, (/^NP`.*'\/NP`.*'.*$/ <: 少なくとも) <- (/^NP`.*'\/NP`.*'.*$/ <: 同じ)) <, (/^NP`.*'\/NP`.*'$/=u <- (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=w <: と)))

delete w
excise u u
