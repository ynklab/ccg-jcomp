/^NP`.*'\/NP`.*'$/ <: (/^S`.*'\\NP`.*'$/=x <- (/^S`.*'\\NP`.*'$/=y <, /^S`.*'\\NP`.*';名詞;形容動詞語幹.*$/) <, (/^S`.*'\/S`.*'$/=z <- (/^<S`.*'\/S`.*'>\\NP`.*'.*$/=w (<: 以上に | <: より | <: ほど) $-- (/^NP`.*'$/=u <: /^S`.*'\\NP`.*'$/))))

excise x x
