/^S`.*form~base.*'\\NP`.*'$/=x <, /^S`.*'\\NP`.*';名詞;形容動詞語幹.*$/ !$-- (/^S`.*'\/S`.*'$/ <- (/^<S`.*'\/S`.*'>\\NP`.*'.*$/ (<: より | <: よりも | <: に比べると | <: 以上に | <: ほど | <: と同じくらい | <: ぐらい))) !$-- (/^S`.*'\/S`.*'.*$/ <: cmp) !> (/^S`.*'\\NP`.*'$/ $-- (/^S`.*'\/S`.*'$/ <- (/^<S`.*'\/S`.*'>\\NP`.*'.*$/ <: より))) !> (/^S`.*'\\NP`.*'$/ $-- (/^S`.*'\/S`.*'$/ <: cmp)) !$-- /^S`.*'\/S`.*';副詞.*$/

