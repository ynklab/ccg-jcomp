/^NP`.*'\/NP`.*'$/ <: (/^S`.*'\\NP`.*'$/=x <- /^S`.*'\\NP`.*';形容詞.*$/=y <, (/^S`.*'\/S`.*'$/=z <- (/^<S`.*'\/S`.*'>\\NP`.*'.*$/=w (<: 以上に | <: より | <: ほど) $-- (/^NP`.*'$/=u <: /^S`.*'\\NP`.*'$/))))

excise x x
adjoinF (NP`case~X1,mod~X2,fin~f'\/NP`case~X1,mod~X2,fin~f' @) y
