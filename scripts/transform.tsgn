/^NP`.*'.*$/ <: の $-- (/^NP`.*'\/NP`.*'$/ <: (/^S`.*mod~adn.*'$/=x <- /^S`.*'\\NP`.*'.*$/=y)) > (/^NP`.*'$/ $++ (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=z (<: より | <: よりも | <: ほど)) > /^NP`.*'\/NP`.*'$/=w)

