/^NP`.*'$/=x $++ (/^<NP`.*'\/NP`.*'>\\NP`.*'.*$/=y <: の) <- (/^NP`.*'$/=z <- (/^NP`.*'.*$/=w <: 多く) <, (/^NP`.*'\/NP`.*'$/=u <- /^<NP`.*'\/NP`.*'>\\NP`.*'.*助数詞.*$/=v))

